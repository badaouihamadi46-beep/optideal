generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Product {
  id          Int      @id @default(autoincrement())
  name        String
  category    String
  brand       String
  description String
  score       Float
  quality     Float    @default(0)
  popularity  Float    @default(0)
  prices      Price[]
  reviews     Review[]
}

model Price {
  id        Int     @id @default(autoincrement())
  shop      String
  amount    Float
  link      String  @default("")
  productId Int
  product   Product @relation(fields: [productId], references: [id])
}

model Review {
  id        Int     @id @default(autoincrement())
  rating    Float
  summary   String
  productId Int
  product   Product @relation(fields: [productId], references: [id])
}
